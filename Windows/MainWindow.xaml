<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ZMusic.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ZMusic"
    SizeChanged="OnWindowSizeChanged">

    <Grid
        x:Name="RootGrid"
        Background="{ThemeResource ZMusicPageBrush}"
        Loaded="OnWindowLoaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏：底部分割线 + 右侧为系统按钮区预留内边距（代码同步 RightInset） -->
        <Border
            Grid.Row="0"
            Background="Transparent"
            BorderBrush="{ThemeResource ZMusicHairlineBrush}"
            BorderThickness="0,0,0,1">
            <Grid
                x:Name="AppTitleBar"
                Padding="16,0,10,0"
                Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- 仅此处参与窗口拖拽；勿把整行设为 SetTitleBar，否则右侧按钮收不到点击 -->
                <Grid
                    x:Name="TitleBarDragRegion"
                    Grid.Column="0"
                    Background="Transparent">
                    <TextBlock
                        x:Name="TitleText"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="Light"
                        Foreground="{ThemeResource ZMusicChromeTextBrush}"
                        CharacterSpacing="80"
                        IsTextSelectionEnabled="False"
                        Text="ZMusic" />
                </Grid>
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="2">
                    <Button
                        x:Name="ThemeCycleButton"
                        Width="36"
                        Height="30"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="OnThemeCycleClick"
                        Content="&#xE793;"
                        CornerRadius="{ThemeResource ZMusicControlRadius}"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="14"
                        Foreground="{ThemeResource ZMusicChromeTextBrush}"
                        ToolTipService.ToolTip="主题：跟随系统 / 浅色 / 深色" />
                    <Button
                        x:Name="SettingsButton"
                        Width="36"
                        Height="30"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Content="&#xE713;"
                        CornerRadius="{ThemeResource ZMusicControlRadius}"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="14"
                        Foreground="{ThemeResource ZMusicChromeTextBrush}"
                        ToolTipService.ToolTip="设置">
                        <Button.Flyout>
                            <Flyout
                                x:Name="SettingsFlyout"
                                Opening="OnSettingsFlyoutOpening"
                                Placement="Bottom">
                                <StackPanel MinWidth="280" Spacing="12">
                                    <TextBlock
                                        Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="API 基址" />
                                    <TextBox
                                        x:Name="SettingsApiUrlBox"
                                        PlaceholderText="http://主机:端口"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="应用主题" />
                                    <ComboBox x:Name="SettingsThemeCombo">
                                        <ComboBoxItem Content="跟随系统" Tag="0" />
                                        <ComboBoxItem Content="浅色" Tag="1" />
                                        <ComboBoxItem Content="深色" Tag="2" />
                                    </ComboBox>
                                    <Button
                                        x:Name="SettingsSaveButton"
                                        Click="OnSettingsSaveClick"
                                        HorizontalAlignment="Stretch"
                                        Content="保存" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <!-- 启动 -->
            <Grid x:Name="SplashPanel" Visibility="Visible" Background="{ThemeResource ZMusicLoginBackdropBrush}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="22">
                    <Border
                        Width="56"
                        Height="56"
                        HorizontalAlignment="Center"
                        Background="{ThemeResource ZMusicAppleAccentBrush}"
                        CornerRadius="14">
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            FontSize="26"
                            Foreground="White"
                            Glyph="&#xE8D6;" />
                    </Border>
                    <ProgressRing
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource ZMusicMutedTextBrush}"
                        IsActive="True" />
                    <TextBlock
                        x:Name="SplashStatusText"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource ZMusicMutedTextBrush}"
                        FontSize="13"
                        Text="正在启动…" />
                </StackPanel>
            </Grid>

            <!-- 登录（类 Apple Music / Apple ID 居中、克制排版） -->
            <Grid x:Name="LoginPanel" Visibility="Collapsed" Background="{ThemeResource ZMusicLoginBackdropBrush}">
                <ScrollViewer Padding="32,40,32,48" VerticalScrollBarVisibility="Auto">
                    <StackPanel
                        MaxWidth="400"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="0">
                        <StackPanel Margin="0,0,0,28" HorizontalAlignment="Center" Spacing="18">
                            <Border
                                Width="72"
                                Height="72"
                                HorizontalAlignment="Center"
                                Background="{ThemeResource ZMusicAppleAccentBrush}"
                                CornerRadius="36">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="34"
                                    Foreground="White"
                                    Glyph="&#xE8D6;" />
                            </Border>
                            <StackPanel Spacing="8">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    Foreground="{ThemeResource ZMusicHeadingBrush}"
                                    FontSize="28"
                                    FontWeight="Light"
                                    Text="登录 ZMusic"
                                    TextAlignment="Center" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                    FontSize="13"
                                    Opacity="0.95"
                                    Text="使用网易云账号授权，以同步歌单与收藏。"
                                    TextAlignment="Center"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </StackPanel>

                        <InfoBar
                            x:Name="LoginErrorBar"
                            Margin="0,0,0,20"
                            CornerRadius="10"
                            IsClosable="True"
                            IsOpen="False"
                            Severity="Error" />

                        <Border
                            Margin="0,0,0,20"
                            Padding="4"
                            Background="{ThemeResource ZMusicSegmentedBgBrush}"
                            CornerRadius="10">
                            <RadioButtons
                                x:Name="LoginMethodRadio"
                                MaxColumns="2"
                                SelectedIndex="0"
                                SelectionChanged="OnLoginMethodSelectionChanged">
                                <x:String>二维码</x:String>
                                <x:String>手机号</x:String>
                            </RadioButtons>
                        </Border>

                        <Grid x:Name="LoginQrSection" Visibility="Visible">
                            <StackPanel Spacing="0">
                                <TextBlock
                                    Margin="0,0,0,12"
                                    Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                    FontSize="12"
                                    Text="使用网易云音乐 App 扫描下方二维码"
                                    TextWrapping="WrapWholeWords" />
                                <Border
                                    Width="220"
                                    Height="220"
                                    Margin="0,0,0,14"
                                    HorizontalAlignment="Center"
                                    Background="{ThemeResource ZMusicQrMatBrush}"
                                    BorderBrush="{ThemeResource ZMusicHairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <Image
                                        x:Name="QrImage"
                                        Margin="12"
                                        Stretch="Uniform" />
                                </Border>
                                <TextBlock
                                    x:Name="QrHintText"
                                    Margin="0,0,0,16"
                                    HorizontalAlignment="Center"
                                    Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                    FontSize="12"
                                    TextAlignment="Center"
                                    TextWrapping="WrapWholeWords"
                                    Text="" />
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="12">
                                    <Button
                                        x:Name="QrRefreshButton"
                                        Padding="16,8"
                                        Click="OnQrRefreshClick"
                                        Content="刷新二维码" />
                                    <ProgressRing
                                        x:Name="QrBusyRing"
                                        Width="22"
                                        Height="22"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="LoginPhoneSection" Visibility="Collapsed">
                            <StackPanel Spacing="0">
                                <TextBlock
                                    Margin="0,0,0,14"
                                    Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                    FontSize="12"
                                    Text="建议优先短信验证码；密码登录可能触发风控。"
                                    TextWrapping="WrapWholeWords" />
                                <TextBox
                                    x:Name="PhoneBox"
                                    Margin="0,0,0,12"
                                    Padding="12,10"
                                    CornerRadius="8"
                                    PlaceholderText="手机号码" />
                                <TextBlock
                                    Margin="0,0,0,8"
                                    Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                    FontSize="11"
                                    Text="验证码" />
                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal" Spacing="10">
                                    <TextBox
                                        x:Name="CaptchaBox"
                                        MinWidth="120"
                                        Padding="12,10"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="8"
                                        InputScope="Number"
                                        PlaceholderText="6 位验证码" />
                                    <Button
                                        x:Name="CaptchaSendButton"
                                        Padding="14,10"
                                        Click="OnCaptchaSendClick"
                                        Content="获取验证码" />
                                </StackPanel>
                                <TextBlock
                                    Margin="0,0,0,8"
                                    Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                    FontSize="11"
                                    Text="密码（可选）" />
                                <PasswordBox
                                    x:Name="PasswordBox"
                                    Margin="0,0,0,18"
                                    Padding="12,10"
                                    CornerRadius="8"
                                    PlaceholderText="登录密码" />
                                <Button
                                    x:Name="PhoneLoginButton"
                                    Padding="0,12"
                                    HorizontalAlignment="Stretch"
                                    Click="OnPhoneLoginClick"
                                    Content="继续"
                                    CornerRadius="10"
                                    Style="{ThemeResource AccentButtonStyle}" />
                            </StackPanel>
                        </Grid>

                        <HyperlinkButton
                            x:Name="GuestLoginButton"
                            Margin="0,28,0,0"
                            Padding="0,8"
                            HorizontalAlignment="Center"
                            Click="OnGuestLoginClick"
                            Content="以游客身份继续" />

                        <TextBlock
                            Margin="0,32,0,0"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource ZMusicMutedTextBrush}"
                            FontSize="11"
                            Opacity="0.75"
                            Text="本客户端需配合自建或第三方网易云 API 服务使用。"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- 主界面（类 macOS「音乐」：侧栏 + 内容 + 底栏 + 全屏播放） -->
            <Grid x:Name="MainPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="252" MinWidth="200" MaxWidth="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 侧栏：资料库 / 歌单 -->
                    <Border
                        Grid.Column="0"
                        Background="{ThemeResource ZMusicSidebarBrush}"
                        BorderBrush="{ThemeResource ZMusicSidebarHairlineBrush}"
                        BorderThickness="0,0,1,0">
                        <Grid Padding="10,18,8,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Margin="6,0,6,14"
                                Orientation="Horizontal"
                                Spacing="10">
                                <Border
                                    Width="28"
                                    Height="28"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource ZMusicAppleAccentBrush}"
                                    CornerRadius="7">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="14"
                                        Foreground="White"
                                        Glyph="&#xE8D6;" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource ZMusicHeadingBrush}"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Text="ZMusic" />
                            </StackPanel>

                            <ListBox
                                x:Name="SidebarNavList"
                                Grid.Row="1"
                                Margin="0,0,0,6"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                SelectionChanged="OnSidebarNavSelectionChanged"
                                SelectionMode="Single">
                                <ListBoxItem IsSelected="True" Tag="home">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <SymbolIcon Symbol="Home" VerticalAlignment="Center" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource ZMusicHeadingBrush}"
                                            FontSize="14"
                                            Text="首页" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="library">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <SymbolIcon Symbol="MusicInfo" VerticalAlignment="Center" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource ZMusicHeadingBrush}"
                                            FontSize="14"
                                            Text="资料库" />
                                    </StackPanel>
                                </ListBoxItem>
                            </ListBox>

                            <Border
                                Grid.Row="2"
                                Height="1"
                                Margin="12,4,12,8"
                                Background="{ThemeResource ZMusicSidebarHairlineBrush}" />

                            <TextBlock
                                Grid.Row="3"
                                Margin="14,0,8,6"
                                Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                FontSize="11"
                                CharacterSpacing="80"
                                Text="播放列表" />

                            <ListView
                                x:Name="PlaylistListView"
                                Grid.Row="4"
                                Padding="0,0,4,0"
                                ContainerContentChanging="OnPlaylistListContainerContentChanging"
                                IsTabStop="False"
                                SelectionChanged="OnPlaylistListSelectionChanged"
                                SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="8,8" Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border
                                                Grid.Column="0"
                                                Width="36"
                                                Height="36"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource ZMusicBorderBrush}"
                                                CornerRadius="6">
                                                <Grid Width="36" Height="36">
                                                    <FontIcon
                                                        x:Name="PlMusicIcon"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                        FontSize="14"
                                                        Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                                        Glyph="&#xE8D6;" />
                                                    <Image
                                                        x:Name="PlCoverImage"
                                                        Width="36"
                                                        Height="36"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        Stretch="UniformToFill"
                                                        Visibility="Collapsed" />
                                                </Grid>
                                            </Border>
                                            <StackPanel
                                                Grid.Column="1"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                Spacing="2">
                                                <TextBlock
                                                    x:Name="PlTitle"
                                                    FontSize="13"
                                                    FontWeight="Light"
                                                    Foreground="{ThemeResource ZMusicHeadingBrush}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    x:Name="PlSub"
                                                    FontSize="10"
                                                    Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                                    Opacity="0.88"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- 主内容 -->
                    <Grid Grid.Column="1" Background="{ThemeResource ZMusicPageBrush}">
                        <Grid x:Name="MainHomePane" Visibility="Visible">
                            <ScrollViewer Padding="36,28,40,32" VerticalScrollBarVisibility="Auto">
                                <StackPanel
                                    MaxWidth="640"
                                    HorizontalAlignment="Left"
                                    Spacing="10">
                                    <TextBlock
                                        x:Name="WelcomeText"
                                        Foreground="{ThemeResource ZMusicHeadingBrush}"
                                        FontSize="34"
                                        FontWeight="Light"
                                        Text="已登录" />
                                    <TextBlock
                                        Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                        FontSize="14"
                                        Opacity="0.9"
                                        Text="在侧栏选择歌单，点击曲目即可全屏播放。底部为播放控制条。"
                                        TextWrapping="WrapWholeWords" />
                                    <Button
                                        x:Name="LogoutButton"
                                        Margin="0,18,0,0"
                                        Padding="16,8"
                                        Click="OnLogoutClick"
                                        Content="退出登录"
                                        CornerRadius="8" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Grid x:Name="MainLibraryPane" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid
                                Grid.Row="0"
                                Margin="28,20,32,8"
                                ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4" VerticalAlignment="Center">
                                    <TextBlock
                                        Foreground="{ThemeResource ZMusicHeadingBrush}"
                                        FontSize="28"
                                        FontWeight="Light"
                                        Text="资料库" />
                                    <TextBlock
                                        x:Name="LibraryPaneHintText"
                                        Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                        FontSize="12"
                                        Opacity="0.85"
                                        Text="进入此页时自动同步"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <ProgressRing
                                    x:Name="LibraryBusyRing"
                                    Grid.Column="1"
                                    Width="22"
                                    Height="22"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed" />
                            </Grid>

                            <TextBlock
                                x:Name="LibraryMessageText"
                                Grid.Row="1"
                                Margin="28,0,32,12"
                                Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                FontSize="12"
                                Opacity="0.95"
                                TextWrapping="WrapWholeWords"
                                Visibility="Collapsed" />

                            <ScrollViewer
                                Grid.Row="2"
                                Padding="28,0,32,24"
                                VerticalScrollBarVisibility="Auto">
                                <Grid RowSpacing="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            x:Name="LibraryDetailTitle"
                                            FontSize="22"
                                            FontWeight="Light"
                                            Foreground="{ThemeResource ZMusicHeadingBrush}"
                                            Text="曲目"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            x:Name="LibraryDetailSubtitle"
                                            FontSize="12"
                                            Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                            Opacity="0.88"
                                            Text="在侧栏选择歌单"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                    <StackPanel
                                        Grid.Row="1"
                                        Orientation="Horizontal"
                                        Spacing="10">
                                        <ProgressRing
                                            x:Name="LibraryTracksRing"
                                            Width="22"
                                            Height="22"
                                            Visibility="Collapsed" />
                                    </StackPanel>
                                    <Grid Grid.Row="2" MinHeight="200">
                                        <TextBlock
                                            x:Name="LibraryTracksEmptyText"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                            FontSize="13"
                                            Text="暂无曲目"
                                            TextAlignment="Center"
                                            Visibility="Visible" />
                                        <ListView
                                            x:Name="TrackListView"
                                            ContainerContentChanging="OnTrackListContainerContentChanging"
                                            IsItemClickEnabled="True"
                                            IsTabStop="False"
                                            ItemClick="OnTrackListItemClick"
                                            SelectionMode="None"
                                            Visibility="Collapsed">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="8,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="40" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock
                                                            x:Name="TrIdx"
                                                            VerticalAlignment="Center"
                                                            Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                                            FontSize="11"
                                                            Opacity="0.75" />
                                                        <StackPanel
                                                            Grid.Column="1"
                                                            Margin="12,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Spacing="3">
                                                            <TextBlock
                                                                x:Name="TrTitle"
                                                                FontSize="15"
                                                                FontWeight="Light"
                                                                Foreground="{ThemeResource ZMusicHeadingBrush}"
                                                                TextTrimming="CharacterEllipsis" />
                                                            <TextBlock
                                                                x:Name="TrSub"
                                                                FontSize="12"
                                                                Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                                                Opacity="0.88"
                                                                TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <TextBlock
                                                            x:Name="TrDur"
                                                            Grid.Column="2"
                                                            Margin="16,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                                            FontSize="11"
                                                            Opacity="0.85" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- 底栏（类 Apple Music 迷你播放条，全局） -->
                <Border
                    x:Name="HomeNowPlayingBar"
                    Grid.Row="1"
                    Padding="16,10,24,10"
                    Background="{ThemeResource ZMusicPlayerBarBrush}"
                    BorderBrush="{ThemeResource ZMusicSidebarHairlineBrush}"
                    BorderThickness="0,1,0,0"
                    Visibility="Collapsed">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Grid.Column="0"
                            Width="48"
                            Height="48"
                            VerticalAlignment="Center"
                            Background="{ThemeResource ZMusicBorderBrush}"
                            CornerRadius="6">
                            <Grid Width="48" Height="48">
                                <FontIcon
                                    x:Name="HomeMiniCoverPh"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="18"
                                    Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                    Glyph="&#xE8D6;" />
                                <Image
                                    x:Name="HomeMiniCoverImage"
                                    Width="48"
                                    Height="48"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Stretch="UniformToFill"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock
                                x:Name="HomeMiniTitleText"
                                FontSize="14"
                                FontWeight="Light"
                                Foreground="{ThemeResource ZMusicHeadingBrush}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                x:Name="HomeMiniArtistText"
                                FontSize="12"
                                Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                Opacity="0.88"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <Button
                                x:Name="HomeMiniPlayPauseButton"
                                Width="40"
                                Height="40"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="OnHomeMiniPlayPauseClick"
                                CornerRadius="20"
                                ToolTipService.ToolTip="播放 / 暂停">
                                <FontIcon
                                    x:Name="HomeMiniPlayPauseIcon"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="16"
                                    Foreground="{ThemeResource ZMusicHeadingBrush}"
                                    Glyph="&#xE102;" />
                            </Button>
                            <Button
                                x:Name="HomeMiniOpenPlayerButton"
                                Width="40"
                                Height="40"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="OnHomeMiniOpenPlayerClick"
                                CornerRadius="20"
                                ToolTipService.ToolTip="全屏播放">
                                <FontIcon
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="16"
                                    Foreground="{ThemeResource ZMusicHeadingBrush}"
                                    Glyph="&#xE944;" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 全屏播放：覆盖侧栏 + 内容 + 底栏 -->
                <Grid
                    x:Name="NowPlayingOverlay"
                    Grid.RowSpan="2"
                    Canvas.ZIndex="40"
                    Padding="20,12,24,20"
                    Background="{ThemeResource ZMusicPageBrush}"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            x:Name="NowPlayingBackButton"
                            Height="36"
                            MinWidth="36"
                            Padding="8,0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="OnNowPlayingBackClick"
                            CornerRadius="{ThemeResource ZMusicControlRadius}"
                            ToolTipService.ToolTip="返回">
                            <FontIcon
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="14"
                                Foreground="{ThemeResource ZMusicHeadingBrush}"
                                Glyph="&#xE72B;" />
                        </Button>
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource ZMusicMutedTextBrush}"
                            FontSize="11"
                            CharacterSpacing="80"
                            Text="正在播放" />
                    </StackPanel>
                    <ScrollViewer
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <Grid MaxWidth="720" HorizontalAlignment="Center" RowSpacing="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border
                                Grid.Row="0"
                                Width="240"
                                Height="240"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{ThemeResource ZMusicBorderBrush}"
                                CornerRadius="16">
                                <Grid Width="240" Height="240">
                                    <FontIcon
                                        x:Name="PlayerCoverPh"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="48"
                                        Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                        Glyph="&#xE8D6;" />
                                    <Image
                                        x:Name="PlayerCoverImage"
                                        Width="240"
                                        Height="240"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Stretch="UniformToFill"
                                        Visibility="Collapsed" />
                                </Grid>
                            </Border>
                            <StackPanel
                                Grid.Row="1"
                                HorizontalAlignment="Center"
                                MaxWidth="640"
                                Spacing="6">
                                <TextBlock
                                    x:Name="PlayerTitleText"
                                    HorizontalAlignment="Center"
                                    FontSize="22"
                                    FontWeight="Light"
                                    Foreground="{ThemeResource ZMusicHeadingBrush}"
                                    Text="未在播放"
                                    TextAlignment="Center"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    x:Name="PlayerArtistText"
                                    HorizontalAlignment="Center"
                                    FontSize="13"
                                    Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                    Opacity="0.9"
                                    Text=""
                                    TextAlignment="Center"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel
                                Grid.Row="2"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8">
                                <Button
                                    x:Name="PlayerModeButton"
                                    Width="52"
                                    Height="40"
                                    Padding="6,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="OnPlayerModeClick"
                                    Content="顺序"
                                    CornerRadius="{ThemeResource ZMusicControlRadius}"
                                    FontSize="12"
                                    Foreground="{ThemeResource ZMusicHeadingBrush}"
                                    ToolTipService.ToolTip="顺序 / 单曲循环 / 随机" />
                                <Button
                                    x:Name="PlayerPrevButton"
                                    Width="48"
                                    Height="48"
                                    Padding="0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="OnPlayerPrevClick"
                                    CornerRadius="{ThemeResource ZMusicControlRadius}"
                                    ToolTipService.ToolTip="上一首">
                                    <FontIcon
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="16"
                                        Foreground="{ThemeResource ZMusicHeadingBrush}"
                                        Glyph="&#xE100;" />
                                </Button>
                                <Button
                                    x:Name="PlayerPlayPauseButton"
                                    Width="56"
                                    Height="56"
                                    Padding="0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="{ThemeResource ZMusicElevatedBrush}"
                                    BorderBrush="{ThemeResource ZMusicHairlineBrush}"
                                    BorderThickness="1"
                                    Click="OnPlayerPlayPauseClick"
                                    CornerRadius="28"
                                    ToolTipService.ToolTip="播放 / 暂停">
                                    <FontIcon
                                        x:Name="PlayerPlayPauseIcon"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="20"
                                        Foreground="{ThemeResource ZMusicHeadingBrush}"
                                        Glyph="&#xE102;" />
                                </Button>
                                <Button
                                    x:Name="PlayerNextButton"
                                    Width="48"
                                    Height="48"
                                    Padding="0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="OnPlayerNextClick"
                                    CornerRadius="{ThemeResource ZMusicControlRadius}"
                                    ToolTipService.ToolTip="下一首">
                                    <FontIcon
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="16"
                                        Foreground="{ThemeResource ZMusicHeadingBrush}"
                                        Glyph="&#xE101;" />
                                </Button>
                                <ProgressRing
                                    x:Name="PlayerBufferingRing"
                                    Width="28"
                                    Height="28"
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed" />
                            </StackPanel>
                            <Border
                                Grid.Row="3"
                                Margin="0,8,0,0"
                                Padding="0,12,0,0"
                                BorderBrush="{ThemeResource ZMusicHairlineBrush}"
                                BorderThickness="0,1,0,0">
                                <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                    <StackPanel Padding="8,8" Spacing="10">
                                        <TextBlock
                                            x:Name="PlayerLyricLineM2"
                                            FontSize="12"
                                            Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                            Opacity="0.5"
                                            TextAlignment="Center"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            x:Name="PlayerLyricLineM1"
                                            FontSize="14"
                                            Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                            Opacity="0.72"
                                            TextAlignment="Center"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            x:Name="PlayerLyricLine0"
                                            FontSize="18"
                                            FontWeight="Light"
                                            Foreground="{ThemeResource ZMusicHeadingBrush}"
                                            TextAlignment="Center"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            x:Name="PlayerLyricLineP1"
                                            FontSize="14"
                                            Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                            Opacity="0.72"
                                            TextAlignment="Center"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            x:Name="PlayerLyricLineP2"
                                            FontSize="12"
                                            Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                            Opacity="0.5"
                                            TextAlignment="Center"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                            <StackPanel Grid.Row="4" Spacing="12">
                                <StackPanel
                                    HorizontalAlignment="Stretch"
                                    MaxWidth="560"
                                    Orientation="Horizontal"
                                    Spacing="12">
                                    <FontIcon
                                        VerticalAlignment="Center"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="16"
                                        Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                        Glyph="&#xE767;" />
                                    <Slider
                                        x:Name="PlayerVolumeSlider"
                                        HorizontalAlignment="Stretch"
                                        Maximum="100"
                                        Minimum="0"
                                        StepFrequency="1"
                                        Value="85"
                                        ValueChanged="OnPlayerVolumeValueChanged" />
                                </StackPanel>
                                <Grid MaxWidth="560" HorizontalAlignment="Stretch" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        x:Name="PlayerTimeText"
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        MinWidth="88"
                                        FontSize="12"
                                        Foreground="{ThemeResource ZMusicMutedTextBrush}"
                                        Text="0:00 / 0:00" />
                                    <Slider
                                        x:Name="PlayerSeekSlider"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Maximum="1000"
                                        Minimum="0"
                                        PointerPressed="OnSeekSliderPointerPressed"
                                        PointerReleased="OnSeekSliderPointerReleased"
                                        StepFrequency="100"
                                        Value="0" />
                                </Grid>
                                <TextBlock
                                    x:Name="PlayerErrorText"
                                    Foreground="#C42B1C"
                                    FontSize="12"
                                    TextWrapping="WrapWholeWords"
                                    Visibility="Collapsed" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
